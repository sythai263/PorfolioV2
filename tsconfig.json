{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@app-types": [
        "./types/index.ts"
      ],
      "@app-types/*": [
        "./types/*"
      ],
      "@components": [
        "./components/index.ts"
      ],
      "@components/*": [
        "./components/*"
      ],
      "@constants": [
        "./constants/index.ts"
      ],
      "@constants/*": [
        "./constants/*"
      ],
      "@data": [
        "./data/index.ts"
      ],
      "@data/*": [
        "./data/*"
      ],
      "@hooks": [
        "./hooks/index.ts"
      ],
      "@hooks/*": [
        "./hooks/*"
      ],
      "@infrastructure": [
        "./infrastructure/index.ts"
      ],
      "@infrastructure/*": [
        "./infrastructure/*"
      ],
      "@lib": [
        "./lib/index.ts"
      ],
      "@lib/*": [
        "./lib/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2017"
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ]
}